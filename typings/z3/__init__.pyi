class Tactic:
    def __init__(self, name: str, ctx: Any = None) -> None: ...
    def __call__(self, goal: Goal, *args: Any, **kwargs: Any) -> ApplyResult: ...

class Probe:
    def __init__(self, name: str, ctx: Any = None) -> None: ...
    def __call__(self, goal: Goal) -> float: ...
    def __eq__(self, other: Any) -> Probe: ...  # type: ignore[override]
    def __ne__(self, other: Any) -> Probe: ...  # type: ignore[override]
    def __le__(self, other: Any) -> Probe: ...
    def __lt__(self, other: Any) -> Probe: ...
    def __ge__(self, other: Any) -> Probe: ...
    def __gt__(self, other: Any) -> Probe: ...

