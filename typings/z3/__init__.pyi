# ── Goal / Tactic ───────────────────────────────────────────────

class Goal:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
    def add(self, *args: Any) -> None: ...
    def as_expr(self) -> BoolRef: ...
    def __len__(self) -> int: ...
