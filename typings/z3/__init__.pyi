"""Type stubs for z3-solver — covers all z3 usage in pyspectre.

z3 is dynamically typed at runtime; these stubs are intentionally permissive
to match z3's actual behavior where ExprRef subtypes are interchangeable
depending on the underlying sort.
"""

from __future__ import annotations

from collections.abc import Iterator
from typing import Any, overload

# ── Sort hierarchy ──────────────────────────────────────────────

class SortRef:
    def name(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __repr__(self) -> str: ...
    def kind(self) -> int: ...

class BoolSortRef(SortRef): ...
class ArithSortRef(SortRef): ...

class BitVecSortRef(SortRef):
    def size(self) -> int: ...

class FPSortRef(SortRef):
    def ebits(self) -> int: ...
    def sbits(self) -> int: ...

class SeqSortRef(SortRef): ...
class ReSortRef(SortRef): ...
class ArraySortRef(SortRef): ...
class DatatypeSortRef(SortRef): ...
class FiniteDomainSortRef(SortRef): ...
class CharSortRef(SortRef): ...
class TypeVarRef(SortRef): ...

# ── AST base ────────────────────────────────────────────────────

class AstRef:
    def sexpr(self) -> str: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def __hash__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def hash(self) -> int: ...
    def ctx_ref(self) -> Any: ...

class AstVector:
    def __len__(self) -> int: ...
    def __getitem__(self, i: int) -> AstRef: ...
    def __iter__(self) -> Iterator[AstRef]: ...
    def __contains__(self, item: AstRef) -> bool: ...
    def push(self, v: AstRef) -> None: ...

# ── Expression hierarchy ────────────────────────────────────────

# NOTE: ExprRef has all arithmetic/comparison operators because z3
# dispatches based on sort at runtime.  Functions like If(), simplify(),
# ModelRef.eval() return ExprRef, and callers routinely use arithmetic
# and comparison operators on those results.

class ExprRef(AstRef):
    def sort(self) -> SortRef: ...
    def sort_kind(self) -> int: ...
    def decl(self) -> FuncDeclRef: ...
    def children(self) -> list[ExprRef]: ...
    def num_args(self) -> int: ...
    def arg(self, i: int) -> ExprRef: ...
    def __eq__(self, other: Any) -> BoolRef: ...  # type: ignore[override]
    def __ne__(self, other: Any) -> BoolRef: ...  # type: ignore[override]
    def __hash__(self) -> int: ...
    def __bool__(self) -> bool: ...
    # Arithmetic operators — valid when sort is Int/Real at runtime
    def __add__(self, other: Any) -> Any: ...
    def __radd__(self, other: Any) -> Any: ...
    def __sub__(self, other: Any) -> Any: ...
    def __rsub__(self, other: Any) -> Any: ...
    def __mul__(self, other: Any) -> Any: ...
    def __rmul__(self, other: Any) -> Any: ...
    def __truediv__(self, other: Any) -> Any: ...
    def __rtruediv__(self, other: Any) -> Any: ...
    def __mod__(self, other: Any) -> Any: ...
    def __rmod__(self, other: Any) -> Any: ...
    def __pow__(self, other: Any) -> Any: ...
    def __neg__(self) -> Any: ...
    # Comparison operators — valid for Int/Real/BV/Seq sorts
    def __le__(self, other: Any) -> BoolRef: ...
    def __lt__(self, other: Any) -> BoolRef: ...
    def __ge__(self, other: Any) -> BoolRef: ...
    def __gt__(self, other: Any) -> BoolRef: ...
    # Value extraction — valid for concrete/evaluated values
    def as_long(self) -> int: ...
    def as_string(self) -> str: ...
    def as_decimal(self, prec: int) -> str: ...
    def as_fraction(self) -> Any: ...
    def as_signed_long(self) -> int: ...
    # Sequence operators (valid when sort is Seq at runtime)
    def __getitem__(self, idx: Any) -> Any: ...
    def __contains__(self, other: Any) -> Any: ...
    def at(self, i: Any) -> Any: ...

class BoolRef(ExprRef):
    def __and__(self, other: BoolRef | ExprRef) -> BoolRef: ...
    def __or__(self, other: BoolRef | ExprRef) -> BoolRef: ...
    def __rand__(self, other: BoolRef | ExprRef) -> BoolRef: ...
    def __ror__(self, other: BoolRef | ExprRef) -> BoolRef: ...
    def __invert__(self) -> BoolRef: ...

class ArithRef(ExprRef):
    def __add__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __radd__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __sub__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __rsub__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __mul__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __rmul__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __truediv__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __rtruediv__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __mod__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __rmod__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __pow__(self, other: ArithRef | ExprRef | int | float) -> ArithRef: ...
    def __neg__(self) -> ArithRef: ...
    def __le__(self, other: ArithRef | ExprRef | int | float) -> BoolRef: ...
    def __lt__(self, other: ArithRef | ExprRef | int | float) -> BoolRef: ...
    def __ge__(self, other: ArithRef | ExprRef | int | float) -> BoolRef: ...
    def __gt__(self, other: ArithRef | ExprRef | int | float) -> BoolRef: ...
    def as_long(self) -> int: ...
    def as_string(self) -> str: ...
    def as_decimal(self, prec: int) -> str: ...
    def as_fraction(self) -> Any: ...
    def is_int(self) -> bool: ...

class IntNumRef(ArithRef):
    def as_long(self) -> int: ...
    def as_string(self) -> str: ...

class RatNumRef(ArithRef):
    def as_long(self) -> int: ...
    def as_decimal(self, prec: int) -> str: ...
    def as_string(self) -> str: ...
    def as_fraction(self) -> Any: ...
    def numerator(self) -> IntNumRef: ...
    def denominator(self) -> IntNumRef: ...
    def numerator_as_long(self) -> int: ...
    def denominator_as_long(self) -> int: ...

class AlgebraicNumRef(ArithRef): ...
class IntRef(ArithRef): ...
class RealRef(ArithRef): ...

