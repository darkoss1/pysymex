# ── ModelRef ────────────────────────────────────────────────────

class ModelRef:
    def decls(self) -> list[FuncDeclRef]: ...
    # eval/evaluate return Any to allow assignment to ArithRef, BoolRef, etc.
    def eval(self, expr: ExprRef, model_completion: bool = False) -> Any: ...
    def evaluate(self, expr: ExprRef, model_completion: bool = False) -> Any: ...
    @overload
    def __getitem__(self, key: FuncDeclRef) -> ExprRef: ...
    @overload
    def __getitem__(self, key: ExprRef) -> ExprRef: ...
    def __getitem__(self, key: Any) -> ExprRef: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[FuncDeclRef]: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def get_interp(self, decl: FuncDeclRef) -> ExprRef | FuncInterp | None: ...
    def num_sorts(self) -> int: ...

# ── FuncInterp ─────────────────────────────────────────────────

class FuncInterp:
    def else_value(self) -> ExprRef: ...
    def num_entries(self) -> int: ...
    def entry(self, i: int) -> FuncEntry: ...
    def arity(self) -> int: ...
    def __len__(self) -> int: ...

class FuncEntry:
    def num_args(self) -> int: ...
    def arg_value(self, i: int) -> ExprRef: ...
    def value(self) -> ExprRef: ...

