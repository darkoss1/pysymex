    def __radd__(self, other: BitVecRef | int) -> BitVecRef: ...
    def __sub__(self, other: BitVecRef | int) -> BitVecRef: ...
    def __rsub__(self, other: BitVecRef | int) -> BitVecRef: ...
    def __mul__(self, other: BitVecRef | int) -> BitVecRef: ...
