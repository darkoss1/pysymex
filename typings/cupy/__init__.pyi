    def attributes(self) -> dict[str, int | str | bool]: ...

    @property
    def cublas_handle(self) -> int: ...

    @property
    def cusolver_handle(self) -> int: ...

    @property
    def cusolver_sp_handle(self) -> int: ...

    @property
    def cusparse_handle(self) -> int: ...

    def synchronize(self) -> None: ...
    def use(self) -> None: ...

    def __enter__(self) -> Device: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: TracebackType | None,
    ) -> None: ...

    def __repr__(self) -> str: ...
    def __int__(self) -> int: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...


class Stream:
    """CUDA stream for asynchronous operations."""

    ptr: int

    def __init__(
        self,
        null: bool = False,
        non_blocking: bool = False,
        ptds: bool = False,
    ) -> None: ...

    def synchronize(self) -> None: ...

    def add_callback(self, callback: Callable[[Stream, int, object], None], arg: object = None) -> None: ...

    def record(self, event: Event | None = None) -> Event: ...

    def wait_event(self, event: Event) -> None: ...

    @property
    def done(self) -> bool: ...

    def __enter__(self) -> Stream: ...
    def __exit__(
        self,
        exc_type: type[BaseException] | None,
        exc_val: BaseException | None,
        exc_tb: TracebackType | None,
    ) -> None: ...


class Event:
