"""Type stubs for CuPy — GPU array library with NumPy-compatible API.

CuPy provides GPU-accelerated array operations using CUDA. These stubs
cover all cupy usage in pysymex and common operations.
"""

from __future__ import annotations

from collections.abc import Callable, Iterator, Sequence
from types import TracebackType
from typing import Generic, Literal, Protocol, SupportsIndex, TypeVar, overload

import numpy as np
import numpy.typing as npt

# ── Type Variables ─────────────────────────────────────────────────

_ScalarType = TypeVar("_ScalarType", bound=np.generic)
_ScalarType_co = TypeVar("_ScalarType_co", bound=np.generic, covariant=True)
_ScalarType2 = TypeVar("_ScalarType2", bound=np.generic)
_IntType = TypeVar("_IntType", bound=np.integer[np.typing.NBitBase])
_FloatType = TypeVar("_FloatType", bound=np.floating[np.typing.NBitBase])

# ── Type Aliases ───────────────────────────────────────────────────

_ShapeLike = int | tuple[int, ...]
_DTypeLike = type[_ScalarType] | np.dtype[_ScalarType] | str
_OrderKACF = Literal["K", "A", "C", "F"]
_OrderCF = Literal["C", "F"]
_OrderACF = Literal["A", "C", "F"]
_CastingKind = Literal["no", "equiv", "safe", "same_kind", "unsafe"]
_SortKind = Literal["quicksort", "mergesort", "heapsort", "stable"]
_ModeKind = Literal["raise", "wrap", "clip"]

# Numeric types that can be used in array operations
_Numeric = int | float | complex | np.generic | ndarray[np.generic]
_ArrayLikeInt = int | np.integer[np.typing.NBitBase] | Sequence[int] | npt.NDArray[np.integer[np.typing.NBitBase]]
_ArrayLikeFloat = float | np.floating[np.typing.NBitBase] | Sequence[float] | npt.NDArray[np.floating[np.typing.NBitBase]]
_ArrayLikeBool = bool | np.bool_ | Sequence[bool] | npt.NDArray[np.bool_]
_ArrayLike = _Numeric | Sequence[_Numeric] | npt.NDArray[np.generic] | ndarray[np.generic]

